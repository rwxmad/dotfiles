#!/bin/bash

# Returns true (exit 0) when a non-eDP display is physically connected.
# Reads DRM connector status directly, independent of the compositor.

for status in /sys/class/drm/card*-*/status; do
  [[ "$status" == *-eDP-*/status ]] && continue
  [[ "$(<"$status")" == "connected" ]] && exit 0
done
exit 1
